#!/usr/bin/env bash
set -euo pipefail

cli_url="${PURPLEFIN_BITWARDEN_CLI_URL:-https://vault.bitwarden.com/download/?app=cli&platform=linux}"
workdir="$(mktemp -d)"

cleanup() {
	rm -rf "${workdir}"
}
trap cleanup EXIT

command -v curl >/dev/null 2>&1 || {
	echo "curl is required to install the native Bitwarden CLI" >&2
	exit 1
}
if ! command -v unzip >/dev/null 2>&1 && ! command -v python3 >/dev/null 2>&1; then
	echo "unzip or python3 is required to extract the native Bitwarden CLI" >&2
	exit 1
fi

cli_zip="${workdir}/bw.zip"
cli_binary="${workdir}/bw"

echo ":: Installing native Bitwarden CLI"
curl --fail --location --show-error --silent --retry 3 --retry-delay 2 --output "${cli_zip}" "${cli_url}"
if command -v unzip >/dev/null 2>&1; then
	unzip -p "${cli_zip}" bw > "${cli_binary}"
else
	python3 - "${cli_zip}" "${cli_binary}" <<'PY'
import sys
import zipfile

archive_path, output_path = sys.argv[1:3]
with zipfile.ZipFile(archive_path) as archive:
    data = archive.read("bw")
with open(output_path, "wb") as output:
    output.write(data)
PY
fi
install -D -m 0755 "${cli_binary}" /usr/libexec/purplefin/bitwarden-cli/bw
ln -sfn ../libexec/purplefin/bitwarden-cli/bw /usr/bin/bw
test -s /usr/libexec/purplefin/bitwarden-cli/bw
