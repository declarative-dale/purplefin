#!/usr/bin/env bash
set -euo pipefail

brew="/home/linuxbrew/.linuxbrew/bin/brew"
brewfile="/usr/share/purplefin/manifests/Brewfile"

if [[ ! -x "${brew}" ]]; then
	echo "Homebrew is not installed at ${brew}; skipping Purplefin Brewfile" >&2
	exit 0
fi

owner_uid="$(stat -c '%u' /home/linuxbrew/.linuxbrew 2>/dev/null || echo '1000')"
owner_name="$(getent passwd "${owner_uid}" | cut -d: -f1 || true)"
owner_home="$(getent passwd "${owner_uid}" | cut -d: -f6 || true)"

if [[ -z "${owner_name}" ]]; then
	echo "No user exists for Homebrew owner UID ${owner_uid}; skipping Purplefin Brewfile" >&2
	exit 0
fi

runuser -u "${owner_name}" -- \
	env HOME="${owner_home:-/var/home/${owner_name}}" HOMEBREW_BUNDLE_FILE="${brewfile}" "${brew}" bundle --file="${brewfile}"
