#!/usr/bin/env bash
set -euo pipefail

helper="${PURPLEFIN_FIRSTBOOT_HELPER:-/usr/libexec/purplefin/lib/rpm-ostree-firstboot.sh}"
task_dir="${PURPLEFIN_FIRSTBOOT_RPM_OSTREE_TASK_DIR:-/usr/libexec/purplefin/firstboot-rpm-ostree.d}"
marker_dir="${PURPLEFIN_FIRSTBOOT_RPM_OSTREE_MARKER_DIR:-/var/lib/purplefin/firstboot}"
reboot_required_file="${PURPLEFIN_FIRSTBOOT_REBOOT_REQUIRED_FILE:-/run/purplefin/firstboot-rpm-ostree/reboot-required}"

# shellcheck source=/usr/libexec/purplefin/lib/rpm-ostree-firstboot.sh
source "${helper}"

if ! command -v rpm-ostree >/dev/null 2>&1; then
	purplefin_firstboot_log "rpm-ostree is unavailable; skipping first-boot rpm-ostree tasks"
	exit 0
fi

install -d -m 0755 "${marker_dir}"
rm -f "${reboot_required_file}"

if purplefin_firstboot_pending_deployment_exists; then
	purplefin_firstboot_log "pending rpm-ostree deployment exists; waiting until after reboot"
	exit 0
fi

shopt -s nullglob
markers=("${marker_dir}"/*.done)
for marker in "${markers[@]}"; do
	task_name="$(basename "${marker}" .done)"
	task="${task_dir}/${task_name}"
	if [[ -f "${task}" && -x "${task}" ]]; then
		continue
	fi

	rm -f "${marker}"
	purplefin_firstboot_log "removed stale marker for retired task ${task_name}"
done

if [[ ! -d "${task_dir}" ]]; then
	purplefin_firstboot_log "task directory ${task_dir} does not exist; nothing to do"
	exit 0
fi

tasks=("${task_dir}"/*)

if ((${#tasks[@]} == 0)); then
	purplefin_firstboot_log "no first-boot rpm-ostree tasks found"
	exit 0
fi

for task in "${tasks[@]}"; do
	if [[ ! -f "${task}" || ! -x "${task}" ]]; then
		continue
	fi

	task_name="$(basename "${task}")"
	if [[ ! "${task_name}" =~ ^[A-Za-z0-9._-]+$ ]]; then
		purplefin_firstboot_log "invalid first-boot task name: ${task_name}"
		exit 1
	fi

	marker="${marker_dir}/${task_name}.done"
	if [[ -e "${marker}" ]]; then
		purplefin_firstboot_log "skipping ${task_name}; marker exists"
		continue
	fi

	purplefin_firstboot_log "running ${task_name}"
	"${task}"
	touch "${marker}"
	purplefin_firstboot_log "completed ${task_name}"

	if [[ -e "${reboot_required_file}" ]] || purplefin_firstboot_pending_deployment_exists; then
		purplefin_firstboot_log "${task_name} staged rpm-ostree changes; stopping remaining tasks until after reboot"
		exit 0
	fi
done
