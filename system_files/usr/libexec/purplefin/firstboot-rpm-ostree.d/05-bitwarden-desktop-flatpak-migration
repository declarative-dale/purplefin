#!/usr/bin/env bash
set -euo pipefail

# shellcheck source=/usr/libexec/purplefin/lib/rpm-ostree-firstboot.sh
source /usr/libexec/purplefin/lib/rpm-ostree-firstboot.sh

if ! rpm -q bitwarden >/dev/null 2>&1; then
	purplefin_firstboot_log "No legacy Bitwarden desktop RPM layer is installed"
	exit 0
fi

purplefin_firstboot_log "Removing the legacy Bitwarden desktop RPM layer; the Flatpak is its replacement"
run_rpm_ostree uninstall bitwarden

