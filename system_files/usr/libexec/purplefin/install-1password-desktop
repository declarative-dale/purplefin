#!/usr/bin/env bash
set -euo pipefail

if [[ -e /usr/lib/opt/1Password/1Password-BrowserSupport ]]; then
	exit 0
fi

if ! command -v rpm-ostree >/dev/null 2>&1; then
	echo "rpm-ostree is unavailable; cannot layer 1Password desktop" >&2
	exit 0
fi

rpm-ostree install --idempotent 1password
systemctl disable purplefin-1password-desktop.service || true

cat >&2 <<'MSG'
1Password desktop has been staged as an rpm-ostree layered package.
Reboot to use the new deployment.
MSG
