#!/usr/bin/env bash
set -euo pipefail

psys_source="${1:-}"
old_line=$'\tdir = debugfs_create_dir("psys", psys->adev->isp->ipu7_dir);'
new_line=$'\tdir = debugfs_create_dir("ipu7-psys", NULL);'

if [[ -z "${psys_source}" || ! -f "${psys_source}" ]]; then
	printf 'usage: %s /path/to/drivers/media/pci/intel/ipu7/psys/ipu-psys.c\n' "$(basename "$0")" >&2
	exit 2
fi

if grep -Fqx "${new_line}" "${psys_source}"; then
	printf 'PSYS debugfs patch already present in %s\n' "${psys_source}" >&2
	exit 0
fi

match_count="$(grep -Fxc "${old_line}" "${psys_source}" || true)"
if [[ "${match_count}" != "1" ]]; then
	printf 'expected PSYS debugfs line is absent or ambiguous in %s\n' "${psys_source}" >&2
	printf 'expected exactly: %s\n' "${old_line}" >&2
	exit 1
fi

sed -i "s|${old_line}|${new_line}|" "${psys_source}"
printf 'patched PSYS debugfs directory in %s\n' "${psys_source}" >&2
