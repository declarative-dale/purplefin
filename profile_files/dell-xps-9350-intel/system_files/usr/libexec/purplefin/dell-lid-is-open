#!/usr/bin/bash
set -euo pipefail

lid_state_root="/proc/acpi/button/lid"
busctl_path="/usr/bin/busctl"
logind_reports_open=false
query_logind=true

case "$#" in
	0) ;;
	2)
		[[ "$1" == "--state-root" && -n "$2" ]] || exit 2
		lid_state_root="$2"
		query_logind=false
		;;
	3)
		[[ "$1" == "--test-sources" && "$2" == /* && -x "$2" && -n "$3" ]] || exit 2
		busctl_path="$2"
		lid_state_root="$3"
		;;
	*) exit 2 ;;
esac

if [[ "${query_logind}" == true ]] && [[ -x "${busctl_path}" ]]; then
	if logind_state="$(
		"${busctl_path}" --system --timeout=500ms get-property \
			org.freedesktop.login1 \
			/org/freedesktop/login1 \
			org.freedesktop.login1.Manager \
			LidClosed 2>/dev/null
	)"; then
		case "${logind_state}" in
		'b false') logind_reports_open=true ;;
		'b true') exit 1 ;;
		esac
	fi
fi

# Cross-check the Dell ACPI state when it exists. Any closed, malformed, or
# mixed ACPI state fails closed even if logind reported open.
shopt -s nullglob
state_files=("${lid_state_root}"/*/state)
if ((${#state_files[@]} > 0)); then
	for state_file in "${state_files[@]}"; do
		label=""
		state=""
		trailing=""
		IFS=$' \t' read -r label state trailing <"${state_file}" || exit 1
		[[ "${label}" == "state:" && "${state}" == "open" && -z "${trailing}" ]] || exit 1
	done
	exit 0
fi

[[ "${logind_reports_open}" == true ]]
