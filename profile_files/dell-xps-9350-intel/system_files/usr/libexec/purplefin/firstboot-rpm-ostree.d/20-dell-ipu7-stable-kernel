#!/usr/bin/env bash
set -euo pipefail

# shellcheck source=/usr/libexec/purplefin/lib/rpm-ostree-firstboot.sh
source /usr/libexec/purplefin/lib/rpm-ostree-firstboot.sh
# shellcheck source=/usr/libexec/purplefin/lib/dell-ipu7.sh
source /usr/libexec/purplefin/lib/dell-ipu7.sh

repo_id="$(purplefin_dell_ipu7_kernel_repo_id)"
repo_file="/etc/yum.repos.d/purplefin-dell-ipu7-mainline-kernel.repo"
repo_tmp="$(mktemp)"

cat >"${repo_tmp}" <<EOF
[${repo_id}]
name=Purplefin Dell IPU7 stable mainline kernel source
baseurl=$(purplefin_dell_ipu7_kernel_repo_baseurl)
type=rpm-md
skip_if_unavailable=False
gpgcheck=1
gpgkey=$(purplefin_dell_ipu7_kernel_repo_gpgkey)
repo_gpgcheck=0
enabled=1
enabled_metadata=1
priority=90
EOF

if ! cmp -s "${repo_tmp}" "${repo_file}"; then
	install -D -m 0644 "${repo_tmp}" "${repo_file}"
	purplefin_firstboot_log "enabled Dell IPU7 stable mainline kernel source ${repo_id}"
fi
rm -f "${repo_tmp}"

if purplefin_dell_ipu7_kernel_supported "$(uname -r)"; then
	purplefin_firstboot_log "booted kernel $(uname -r) already satisfies Dell IPU7 Linux 7.1.x gate"
	exit 0
fi

if ! command -v dnf5 >/dev/null 2>&1; then
	purplefin_firstboot_log "dnf5 is required to query ${repo_id} for stable Linux 7.1.x kernels"
	exit 1
fi

mapfile -t kernel_evrs < <(
	dnf5 -q --refresh --disablerepo='*' --enablerepo="${repo_id}" repoquery --available --qf '%{evr}' kernel-core | sort -u
)

selected_evr="$(printf '%s\n' "${kernel_evrs[@]}" | purplefin_dell_ipu7_select_kernel_evr)" || {
	purplefin_firstboot_log "no stable Linux 7.1.x kernel-core package found in ${repo_id}; release candidates are intentionally rejected"
	exit 1
}

kernel_packages=(
	kernel
	kernel-core
	kernel-modules
	kernel-modules-core
	kernel-modules-extra
)
override_specs=()

for package in "${kernel_packages[@]}"; do
	match="$(
		dnf5 -q --disablerepo='*' --enablerepo="${repo_id}" repoquery --available --qf '%{name}\t%{evr}\t%{arch}' "${package}" |
			awk -F '\t' -v evr="${selected_evr}" '$2 == evr { print $1 "\t" $2 "\t" $3; exit }'
	)"

	if [[ -z "${match}" ]]; then
		purplefin_firstboot_log "missing ${package}-${selected_evr} in ${repo_id}; cannot stage a coherent Dell IPU7 kernel set"
		exit 1
	fi

	IFS=$'\t' read -r name evr arch <<<"${match}"
	override_specs+=("${name}-${evr#0:}.${arch}")
done

purplefin_firstboot_log "staging Dell IPU7 kernel override for stable Linux ${selected_evr#0:} from ${repo_id}"
run_rpm_ostree override replace --experimental --from repo="${repo_id}" "${override_specs[@]}"
purplefin_firstboot_log "Dell IPU7 kernel override staged; reboot into the Linux ${selected_evr#0:} deployment before DKMS setup"
