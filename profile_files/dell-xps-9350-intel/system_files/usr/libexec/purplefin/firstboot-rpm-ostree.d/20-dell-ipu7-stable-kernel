#!/usr/bin/env bash
set -euo pipefail

# shellcheck source=/usr/libexec/purplefin/lib/rpm-ostree-firstboot.sh
source /usr/libexec/purplefin/lib/rpm-ostree-firstboot.sh
# shellcheck source=/usr/libexec/purplefin/lib/dell-ipu7.sh
source /usr/libexec/purplefin/lib/dell-ipu7.sh

repo_id="$(purplefin_dell_ipu7_kernel_repo_id)"
repo_file="/etc/yum.repos.d/purplefin-dell-ipu7-mainline-kernel.repo"
repo_tmp="$(mktemp)"

kernel_build_packages=(
	kernel-devel
	kernel-devel-matched
	kernel-headers
)

fail() {
	purplefin_firstboot_log "$*"
	exit 1
}

write_kernel_repo() {
	cat >"${repo_tmp}" <<EOF
[${repo_id}]
name=Purplefin Dell IPU7 pinned mainline kernel source
baseurl=$(purplefin_dell_ipu7_kernel_repo_baseurl)
type=rpm-md
skip_if_unavailable=False
gpgcheck=1
gpgkey=$(purplefin_dell_ipu7_kernel_repo_gpgkey)
repo_gpgcheck=0
enabled=1
enabled_metadata=1
priority=90
EOF

	if ! cmp -s "${repo_tmp}" "${repo_file}"; then
		install -D -m 0644 "${repo_tmp}" "${repo_file}"
		purplefin_firstboot_log "enabled Dell IPU7 pinned mainline kernel source ${repo_id}"
	fi
	rm -f "${repo_tmp}"
}

collect_package_specs() {
	local evr="$1"
	local arch="$2"
	shift 2
	local repoquery_output specs
	local repoquery_format=$'%{name}\t%{evr}\t%{arch}\n'

	repoquery_output="$(
		dnf5 -q --refresh --disablerepo='*' --enablerepo="${repo_id}" repoquery --available --qf "${repoquery_format}" "$@" | sort -u
	)"
	specs="$(printf '%s\n' "${repoquery_output}" | purplefin_dell_ipu7_collect_package_specs_from_repoquery "${evr}" "${arch}" "$@")" || return 1
	printf '%s\n' "${specs}"
}

write_kernel_repo

if purplefin_dell_ipu7_mark_booted_kernel_ok_if_pending; then
	purplefin_firstboot_log "Dell IPU7 baked kernel boot confirmed from legacy pending marker: $(purplefin_dell_ipu7_uname_r)"
	exit 0
fi
if purplefin_dell_ipu7_refuse_failed_kernel_stage; then
	exit 1
fi

ok_evr="$(purplefin_dell_ipu7_ok_kernel_evr || true)"
if [[ -n "${ok_evr}" ]]; then
	purplefin_dell_ipu7_assert_booted_kernel
	purplefin_firstboot_log "booted kernel $(purplefin_dell_ipu7_uname_r) already matches validated Dell IPU7 kernel ${ok_evr}"
	exit 0
fi

target_release="$(purplefin_dell_ipu7_uname_r)"
target_arch="$(purplefin_dell_ipu7_uname_m)"
target_evr="$(purplefin_dell_ipu7_booted_kernel_evr)"

if ! purplefin_dell_ipu7_kernel_supported "${target_release}" || purplefin_dell_ipu7_kernel_evr_denied "${target_evr}"; then
	fail "Dell IPU7 profile booted unsupported kernel ${target_release}; rebuild the Dell image with the validated Linux 7.1.x kernel baked in"
fi

config_path="$(purplefin_dell_ipu7_find_local_kernel_config "${target_release}")" || {
	fail "Dell IPU7 baked kernel config for ${target_release} is missing"
}
purplefin_firstboot_log "validating Dell IPU7 baked kernel config from ${config_path}"
purplefin_dell_ipu7_validate_kernel_config_file "${config_path}" || {
	fail "baked kernel ${target_release} does not expose the required Dell IPU7 config flags"
}

if [[ -f /usr/share/purplefin/dell-ipu7/kernel-build-packages ]]; then
	mapfile -t build_specs < /usr/share/purplefin/dell-ipu7/kernel-build-packages
else
	if ! command -v dnf5 >/dev/null 2>&1; then
		fail "dnf5 is required to query ${repo_id} for Dell IPU7 kernel build packages"
	fi
	build_specs_output="$(collect_package_specs "${target_evr}" "${target_arch}" "${kernel_build_packages[@]}")" || {
		fail "missing kernel-devel, kernel-devel-matched, or kernel-headers for Dell IPU7 kernel ${target_evr} in ${repo_id}"
	}
	mapfile -t build_specs <<<"${build_specs_output}"
fi
if ((${#build_specs[@]} == 0)); then
	fail "Dell IPU7 build package manifest is empty for ${target_release}"
fi

for build_spec in "${build_specs[@]}"; do
	[[ -n "${build_spec}" ]] || continue
	if [[ "${build_spec}" != *"${target_evr}"* ]]; then
		fail "recorded Dell IPU7 build package ${build_spec} does not match booted kernel ${target_release}"
	fi
done

purplefin_dell_ipu7_record_kernel_booted_ok "${target_evr}" "${target_release}" "${build_specs[@]}"
purplefin_firstboot_log "Dell IPU7 baked kernel ${target_release} validated"
