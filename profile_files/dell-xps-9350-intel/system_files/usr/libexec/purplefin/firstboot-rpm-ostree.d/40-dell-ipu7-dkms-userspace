#!/usr/bin/env bash
set -euo pipefail

# shellcheck source=/usr/libexec/purplefin/lib/rpm-ostree-firstboot.sh
source /usr/libexec/purplefin/lib/rpm-ostree-firstboot.sh
# shellcheck source=/usr/libexec/purplefin/lib/dell-ipu7.sh
source /usr/libexec/purplefin/lib/dell-ipu7.sh

purplefin_dell_ipu7_assert_booted_kernel

/usr/libexec/purplefin/dell-ipu7-setup

install -d -m 0755 /var/lib/purplefin/dell-ipu7
touch /var/lib/purplefin/dell-ipu7/setup.done
purplefin_firstboot_log "Dell IPU7 DKMS modules and /usr/local libcamera setup completed"
