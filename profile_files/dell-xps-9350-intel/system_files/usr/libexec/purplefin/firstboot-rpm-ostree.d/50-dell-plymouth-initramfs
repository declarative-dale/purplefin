#!/usr/bin/env bash
set -euo pipefail

# shellcheck source=/usr/libexec/purplefin/lib/rpm-ostree-firstboot.sh
source /usr/libexec/purplefin/lib/rpm-ostree-firstboot.sh

if [[ ! -f /etc/plymouth/plymouthd.conf ]]; then
	purplefin_firstboot_log "Plymouth configuration is absent; skipping Dell initramfs tracking"
	exit 0
fi

mapfile -d '' plymouth_files < <(find /etc/plymouth -type f -print0 | sort -z)
if ((${#plymouth_files[@]} == 0)); then
	purplefin_firstboot_log "no Plymouth files found under /etc/plymouth"
	exit 0
fi

args=()
for file in "${plymouth_files[@]}"; do
	args+=("--track=${file}")
done

run_rpm_ostree initramfs-etc "${args[@]}"
run_rpm_ostree initramfs-etc --force-sync

purplefin_firstboot_log "Dell Plymouth files have been tracked into the initramfs; reboot to use the new deployment"
