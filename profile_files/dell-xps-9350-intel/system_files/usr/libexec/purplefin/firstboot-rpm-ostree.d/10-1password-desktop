#!/usr/bin/env bash
set -euo pipefail

# shellcheck source=/usr/libexec/purplefin/lib/rpm-ostree-firstboot.sh
source /usr/libexec/purplefin/lib/rpm-ostree-firstboot.sh

if [[ -e /usr/lib/opt/1Password/1Password-BrowserSupport ]]; then
	purplefin_firstboot_log "1Password desktop is already present"
	exit 0
fi

run_rpm_ostree install --idempotent 1password

purplefin_firstboot_log "1Password desktop has been staged as an rpm-ostree layered package; reboot to use the new deployment"
