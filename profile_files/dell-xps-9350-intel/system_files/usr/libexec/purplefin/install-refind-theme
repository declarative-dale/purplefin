#!/usr/bin/env bash
set -euo pipefail

theme_name="rEFInd-Regular-Dark"
source_dir="${PURPLEFIN_REFIND_THEME_SOURCE:-/usr/share/purplefin/refind/themes/${theme_name}}"
include_line="include themes/${theme_name}/theme.conf"

log() {
	printf 'purplefin-refind-theme: %s\n' "$*" >&2
}

if [[ ! -f "${source_dir}/theme.conf" ]]; then
	log "theme source ${source_dir} is missing; skipping"
	exit 0
fi

candidate_dirs=()
if [[ -n "${PURPLEFIN_REFIND_DIR:-}" ]]; then
	candidate_dirs+=("${PURPLEFIN_REFIND_DIR}")
fi
candidate_dirs+=(
	/boot/efi/EFI/refind
	/boot/EFI/refind
	/efi/EFI/refind
)

refind_dir=""
for candidate_dir in "${candidate_dirs[@]}"; do
	if [[ -f "${candidate_dir}/refind.conf" ]]; then
		refind_dir="${candidate_dir}"
		break
	fi
done

if [[ -z "${refind_dir}" ]]; then
	log "rEFInd config not found; skipping"
	exit 0
fi

target_dir="${refind_dir}/themes/${theme_name}"
case "${target_dir}" in
	*/themes/"${theme_name}") ;;
	*)
		log "refusing to replace unexpected theme target ${target_dir}"
		exit 1
		;;
esac

rm -rf -- "${target_dir}"
install -d "${target_dir}"
cp -a "${source_dir}/." "${target_dir}/"

config="${refind_dir}/refind.conf"
if grep -Eq '^[[:space:]]*include[[:space:]]+themes/rEFInd-Regular-Dark/theme\.conf([[:space:]]|$)' "${config}"; then
	log "theme include already present in ${config}"
else
	printf '\n%s\n' "${include_line}" >>"${config}"
	log "added theme include to ${config}"
fi

log "installed ${theme_name} into ${target_dir}"
