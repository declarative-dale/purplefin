#!/usr/bin/env bash
set -euo pipefail

sysfs_root="${PURPLEFIN_DELL_IPU7_SYSFS_ROOT:-/sys}"
sensor_id="${PURPLEFIN_DELL_IPU7_SENSOR_ID:-i2c-OVTI02C1:00}"
sensor_device="${sysfs_root}/bus/i2c/devices/${sensor_id}"
sensor_driver="${sysfs_root}/bus/i2c/drivers/ov02c10"

[[ -e "${sensor_device}" ]] || exit 1
[[ -e "${sensor_driver}/bind" ]] || exit 1

if [[ -L "${sensor_device}/driver" ]] &&
	[[ "$(basename "$(readlink -f "${sensor_device}/driver")")" == "ov02c10" ]]; then
	exit 0
fi

printf '%s\n' "${sensor_id}" >"${sensor_driver}/bind"

[[ -L "${sensor_device}/driver" ]] &&
	[[ "$(basename "$(readlink -f "${sensor_device}/driver")")" == "ov02c10" ]]
