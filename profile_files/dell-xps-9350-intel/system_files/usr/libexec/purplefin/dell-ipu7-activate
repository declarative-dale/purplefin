#!/usr/bin/env bash
set -euo pipefail

rebind_helper=/usr/libexec/purplefin/dell-ipu7-rebind-sensor

for module in usbio gpio_usbio i2c_usbio intel_cvs; do
	modprobe "${module}"
done

for attempt in {1..20}; do
	if "${rebind_helper}"; then
		exit 0
	fi
	sleep 0.25
done

echo "Dell IPU7 activation failed: OVTI02C1 did not bind to ov02c10 after intel_cvs loaded" >&2
exit 1
