#!/usr/bin/env bash
set -euo pipefail

librepods_dir="/usr/libexec/purplefin/librepods"
librepods_binary="${librepods_dir}/librepods"

if [[ ! -x "${librepods_binary}" ]]; then
	echo "Librepods binary is missing or not executable: ${librepods_binary}" >&2
	exit 1
fi

(
	cd "${librepods_dir}"
	sha256sum -c librepods.sha256
)

ln -sfn ../libexec/purplefin/librepods/librepods /usr/bin/librepods
test -x /usr/bin/librepods
