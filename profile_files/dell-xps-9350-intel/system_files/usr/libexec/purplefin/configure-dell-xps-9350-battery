#!/usr/bin/env bash
set -euo pipefail

readonly program="${0##*/}"
readonly vendor_config="${PURPLEFIN_DELL_BATTERY_VENDOR_CONFIG:-/usr/lib/purplefin/dell-xps-9350-battery.conf}"
readonly local_config="${PURPLEFIN_DELL_BATTERY_CONFIG:-/etc/purplefin/dell-xps-9350-battery.conf}"
readonly dmi_root="${PURPLEFIN_DELL_BATTERY_DMI_ROOT:-/sys/class/dmi/id}"
readonly power_supply_root="${PURPLEFIN_DELL_BATTERY_POWER_SUPPLY_ROOT:-/sys/class/power_supply}"
readonly busctl_command="${PURPLEFIN_DELL_BATTERY_BUSCTL:-/usr/bin/busctl}"
readonly upower_command="${PURPLEFIN_DELL_BATTERY_UPOWER:-/usr/bin/upower}"
readonly upower_service="${PURPLEFIN_DELL_BATTERY_UPOWER_SERVICE:-org.freedesktop.UPower}"
readonly upower_interface="org.freedesktop.UPower.Device"

enabled=true
start_threshold=75
end_threshold=80

log() {
	printf '%s: %s\n' "${program}" "$*" >&2
}

die() {
	log "$*"
	exit 1
}

trim() {
	local value="$1"

	value="${value#"${value%%[![:space:]]*}"}"
	value="${value%"${value##*[![:space:]]}"}"
	printf '%s' "${value}"
}

load_config() {
	local config_file="$1"
	local line key value
	local line_number=0

	[[ -e "${config_file}" ]] || return 0
	[[ -f "${config_file}" && -r "${config_file}" ]] || die "cannot read configuration ${config_file}"

	while IFS= read -r line || [[ -n "${line}" ]]; do
		line_number=$((line_number + 1))
		line="${line%%#*}"
		line="$(trim "${line}")"
		[[ -n "${line}" ]] || continue
		[[ "${line}" == *=* ]] || die "invalid entry at ${config_file}:${line_number}"

		key="$(trim "${line%%=*}")"
		value="$(trim "${line#*=}")"
		case "${key}" in
			ENABLED)
				case "${value,,}" in
					1|true|yes|on) enabled=true ;;
					0|false|no|off) enabled=false ;;
					*) die "invalid ENABLED value at ${config_file}:${line_number}" ;;
				esac
				;;
			START_THRESHOLD)
				[[ "${value}" =~ ^(0|[1-9][0-9]*)$ ]] || die "invalid START_THRESHOLD at ${config_file}:${line_number}"
				start_threshold="${value}"
				;;
			END_THRESHOLD)
				[[ "${value}" =~ ^(0|[1-9][0-9]*)$ ]] || die "invalid END_THRESHOLD at ${config_file}:${line_number}"
				end_threshold="${value}"
				;;
			*)
				die "unsupported key ${key} at ${config_file}:${line_number}"
				;;
		esac
	done <"${config_file}"
}

read_attribute() {
	local path="$1"

	[[ -r "${path}" ]] || die "cannot read ${path}"
	<"${path}" tr -d '\n'
}

write_attribute() {
	local path="$1"
	local value="$2"

	if ! printf '%s\n' "${value}" >"${path}"; then
		die "failed to write ${value} to ${path}"
	fi
}

supports_charge_type() {
	local available="$1"
	local candidate
	local candidates=()

	available="${available//\[/}"
	available="${available//\]/}"
	read -r -a candidates <<<"${available}"
	for candidate in "${candidates[@]}"; do
		[[ "${candidate}" == "Custom" ]] && return 0
	done
	return 1
}

custom_charge_type_selected() {
	local selected="$1"

	[[ "${selected}" == "Custom" || "${selected}" == *"[Custom]"* ]]
}

upower_object_for_battery() {
	local battery_name="$1"

	[[ "${battery_name}" =~ ^[A-Za-z0-9_]+$ ]] || return 1
	printf '/org/freedesktop/UPower/devices/battery_%s\n' "${battery_name}"
}

upower_api_available() {
	local object="$1"
	local introspection

	introspection="$("${busctl_command}" --system --no-pager --no-legend --timeout=10s \
		introspect "${upower_service}" "${object}" "${upower_interface}" 2>/dev/null)" || return 2
	grep -q 'EnableChargeThreshold' <<<"${introspection}" || return 1
	grep -q 'ChargeThresholdSupported' <<<"${introspection}" || return 1
	grep -q 'ChargeThresholdEnabled' <<<"${introspection}" || return 1
}

upower_boolean_property() {
	local object="$1"
	local property="$2"
	local result

	result="$("${busctl_command}" --system --no-pager --no-legend --timeout=10s \
		get-property "${upower_service}" "${object}" "${upower_interface}" "${property}")" || return 1
	case "${result}" in
		'b true') return 0 ;;
		'b false') return 1 ;;
		*) die "UPower returned an invalid ${property} value for ${object}: ${result}" ;;
	esac
}

enable_upower_charge_threshold() {
	local battery_name="$1"
	local object enumerated_devices status

	[[ -x "${busctl_command}" ]] || {
		log "UPower D-Bus client ${busctl_command} is unavailable; using direct sysfs fallback"
		return 2
	}
	[[ -x "${upower_command}" ]] || {
		log "UPower client ${upower_command} is unavailable; using direct sysfs fallback"
		return 2
	}
	object="$(upower_object_for_battery "${battery_name}")" || {
		log "cannot map ${battery_name} to a UPower object; using direct sysfs fallback"
		return 2
	}
	enumerated_devices="$("${upower_command}" --enumerate)" || die "failed to enumerate UPower devices"
	if ! grep -Fxq "${object}" <<<"${enumerated_devices}"; then
		log "UPower does not expose ${battery_name}; using direct sysfs fallback"
		return 2
	fi
	if upower_api_available "${object}"; then
		:
	else
		status=$?
		if ((status == 1)); then
			log "UPower does not expose the charge-threshold API for ${battery_name}; using direct sysfs fallback"
			return 2
		fi
		die "failed to introspect the UPower charge-threshold API for ${battery_name}"
	fi
	upower_boolean_property "${object}" ChargeThresholdSupported ||
		die "UPower reports that charge thresholds are unsupported for ${battery_name}"

	"${busctl_command}" --system --no-pager --no-legend --timeout=10s \
		--allow-interactive-authorization=no \
		call "${upower_service}" "${object}" "${upower_interface}" EnableChargeThreshold b true >/dev/null ||
		die "UPower failed to enable charge thresholds for ${battery_name}"
	upower_boolean_property "${object}" ChargeThresholdEnabled ||
		die "UPower did not enable charge thresholds for ${battery_name}"
	log "enabled the UPower charge-threshold policy for ${battery_name}"
	printf '%s\n' "${object}"
}

configure_battery() {
	local battery="$1"
	local battery_name="${battery##*/}"
	local charge_types_path="${battery}/charge_types"
	local start_path="${battery}/charge_control_start_threshold"
	local end_path="${battery}/charge_control_end_threshold"
	local available selected current_start current_end actual_start actual_end path upower_object status
	local upower_managed=false

	for path in "${charge_types_path}" "${start_path}" "${end_path}"; do
		[[ -e "${path}" ]] || die "${battery} does not expose ${path##*/}"
	done

	if upower_object="$(enable_upower_charge_threshold "${battery_name}")"; then
		upower_managed=true
	else
		status=$?
		((status == 2)) || exit "${status}"
	fi

	# UPower may have just restored its saved policy. Reassert the Dell-specific
	# charge type and configured thresholds, then verify both interfaces.
	available="$(read_attribute "${charge_types_path}")"
	supports_charge_type "${available}" || die "${battery} does not support the Custom charge type"
	write_attribute "${charge_types_path}" Custom
	selected="$(read_attribute "${charge_types_path}")"
	custom_charge_type_selected "${selected}" || die "${battery} did not select the Custom charge type: ${selected}"

	current_start="$(read_attribute "${start_path}")"
	current_end="$(read_attribute "${end_path}")"
	[[ "${current_start}" =~ ^[0-9]+$ ]] || die "${battery} returned an invalid start threshold: ${current_start}"
	[[ "${current_end}" =~ ^[0-9]+$ ]] || die "${battery} returned an invalid end threshold: ${current_end}"
	if ((start_threshold >= current_end)); then
		# Raise the end threshold first so the intermediate range remains valid.
		write_attribute "${end_path}" "${end_threshold}"
		write_attribute "${start_path}" "${start_threshold}"
	else
		# Lowering the start threshold first is safe for disjoint and overlapping ranges.
		write_attribute "${start_path}" "${start_threshold}"
		write_attribute "${end_path}" "${end_threshold}"
	fi

	actual_start="$(read_attribute "${start_path}")"
	actual_end="$(read_attribute "${end_path}")"
	selected="$(read_attribute "${charge_types_path}")"
	custom_charge_type_selected "${selected}" || die "${battery} changed away from the Custom charge type: ${selected}"
	[[ "${actual_start}" == "${start_threshold}" ]] || die "${battery} start threshold is ${actual_start}, expected ${start_threshold}"
	[[ "${actual_end}" == "${end_threshold}" ]] || die "${battery} end threshold is ${actual_end}, expected ${end_threshold}"
	if [[ "${upower_managed}" == true ]]; then
		upower_boolean_property "${upower_object}" ChargeThresholdEnabled ||
			die "UPower disabled charge thresholds while configuring ${battery_name}"
	fi

	log "configured ${battery##*/} for Custom charging at ${actual_start}-${actual_end}%"
}

load_config "${vendor_config}"
load_config "${local_config}"

if [[ "${enabled}" != true ]]; then
	log "disabled by ${local_config}"
	exit 0
fi

((start_threshold >= 1 && start_threshold <= 99)) || die "START_THRESHOLD must be between 1 and 99"
((end_threshold >= 2 && end_threshold <= 100)) || die "END_THRESHOLD must be between 2 and 100"
((start_threshold < end_threshold)) || die "START_THRESHOLD must be lower than END_THRESHOLD"

sys_vendor="$(read_attribute "${dmi_root}/sys_vendor")"
product_name="$(read_attribute "${dmi_root}/product_name")"
if [[ "${sys_vendor}" != "Dell Inc." || "${product_name}" != "XPS 13 9350" ]]; then
	log "skipping unsupported system ${sys_vendor} ${product_name}"
	exit 0
fi

shopt -s nullglob
batteries=("${power_supply_root}"/BAT*)
configured=0
for battery in "${batteries[@]}"; do
	[[ -d "${battery}" ]] || continue
	[[ "$(read_attribute "${battery}/type")" == "Battery" ]] || continue
	configure_battery "${battery}"
	configured=$((configured + 1))
done

((configured > 0)) || die "no configurable system battery found under ${power_supply_root}"
