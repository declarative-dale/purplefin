#%PAM-1.0

# An open lid uses the authselect-managed fingerprint-first stack. A closed or
# indeterminate lid uses the local-password-only stack.
# pam_exec returns ignore during pam_setcred; that path also belongs in the
# normal system-auth stack and therefore uses the same two-entry jump.
auth [success=2 ignore=2 default=ignore] pam_exec.so quiet quiet_log /usr/bin/env -i /usr/libexec/purplefin/dell-lid-is-open
auth substack purplefin-dell-password-auth
auth [success=1 default=die] pam_permit.so
auth substack system-auth
