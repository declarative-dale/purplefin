#!/usr/bin/env bash
set -euo pipefail

source_dir="${PURPLEFIN_ZSH_DEFAULTS_SOURCE:-/usr/share/purplefin/zsh}"
config_home="${XDG_CONFIG_HOME:-${HOME}/.config}"
state_home="${XDG_STATE_HOME:-${HOME}/.local/state}"
cache_home="${XDG_CACHE_HOME:-${HOME}/.cache}"
target_dir="${PURPLEFIN_ZSH_DEFAULTS_TARGET:-${config_home}/zsh}"
bootstrap_file="${PURPLEFIN_ZSH_BOOTSTRAP_TARGET:-${HOME}/.zshenv}"

if [[ ! -e "${target_dir}" ]]; then
	install -d -m 0755 "$(dirname "${target_dir}")"
	cp -a "${source_dir}" "${target_dir}"
fi

if [[ ! -e "${bootstrap_file}" ]]; then
	install -m 0644 "${source_dir}/.zshenv" "${bootstrap_file}"
fi

install -d -m 0700 "${state_home}/zsh"
install -d -m 0755 "${cache_home}/zsh"
