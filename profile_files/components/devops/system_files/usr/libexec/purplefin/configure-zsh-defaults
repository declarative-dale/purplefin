#!/usr/bin/env bash
set -euo pipefail

# Fedora reads /etc/zshenv, while some zsh layouts use /etc/zsh/zshenv.
# Configure both when present so the image remains portable across base images.
IFS=: read -r -a zshenv_paths <<< "${PURPLEFIN_ZSHENV_PATHS:-/etc/zshenv:/etc/zsh/zshenv}"

for zshenv_path in "${zshenv_paths[@]}"; do
	[[ -f "${zshenv_path}" ]] || continue
	if grep -qF '# Purplefin zsh configuration' "${zshenv_path}"; then
		continue
	fi

	printf '%s\n' \
		'' \
		'# Purplefin zsh configuration' \
		'if [[ -z "$XDG_CONFIG_HOME" ]]' \
		'then' \
		'    export XDG_CONFIG_HOME="$HOME/.config"' \
		'fi' \
		'' \
		'if [[ -d "$XDG_CONFIG_HOME/zsh" ]]' \
		'then' \
		'    export ZDOTDIR="$XDG_CONFIG_HOME/zsh"' \
		'fi' >> "${zshenv_path}"
done
