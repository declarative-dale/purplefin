#!/usr/bin/env bash
set -euo pipefail

source_config="${PURPLEFIN_GHOSTTY_DEFAULTS_SOURCE:-/usr/share/purplefin/ghostty/config.ghostty}"
target_config="${XDG_CONFIG_HOME:-${HOME}/.config}/ghostty/config.ghostty"

if [[ -e "${target_config}" ]]; then
	exit 0
fi

install -d -m 0755 "$(dirname "${target_config}")"
install -m 0644 "${source_config}" "${target_config}"
