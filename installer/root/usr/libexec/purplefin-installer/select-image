#!/usr/bin/env bash
# Select and verify a Purplefin bootc payload for the Anaconda integration.
set -euo pipefail

catalog=${PURPLEFIN_INSTALLER_CATALOG:-/usr/share/purplefin-installer/catalog.tsv}
registry=${PURPLEFIN_IMAGE_REGISTRY:-ghcr.io/declarative-dale/purplefin}
dmi_root=${PURPLEFIN_DMI_ROOT:-/sys/class/dmi/id}
issuer=${PURPLEFIN_COSIGN_ISSUER:-https://token.actions.githubusercontent.com}
identity=${PURPLEFIN_COSIGN_IDENTITY:-'^https://github.com/declarative-dale/purplefin/\.github/workflows/build\.yml@refs/heads/main$'}

usage() {
  echo "usage: $0 detect-hardware | list-presets | resolve PRESET [HARDWARE]" >&2
  exit 2
}

read_dmi() {
  local name=$1
  [[ -r "${dmi_root}/${name}" ]] && tr -d '\n' <"${dmi_root}/${name}" || true
}

detect_hardware() {
  local vendor product
  vendor=$(read_dmi sys_vendor)
  product=$(read_dmi product_name)
  if [[ ${vendor} == *Dell* && ${product} == *"XPS 13 9350"* ]]; then
    printf '%s\n' dell-xps-9350-intel
  else
    printf '%s\n' generic
  fi
}

find_entry() {
  local wanted_preset=$1 wanted_hardware=$2
  awk -F '\t' -v preset="${wanted_preset}" -v hardware="${wanted_hardware}" \
    '$1 !~ /^#/ && $1 == preset && $2 == hardware { print; exit }' "${catalog}"
}

case ${1:-} in
  detect-hardware)
    detect_hardware
    ;;
  list-presets)
    hardware=$(detect_hardware)
    awk -F '\t' -v hardware="${hardware}" '$1 !~ /^#/ && $2 == hardware { print $1 "\t" $5 }' "${catalog}"
    ;;
  resolve)
    preset=${2:-}
    [[ -n ${preset} ]] || usage
    hardware=${3:-$(detect_hardware)}
    entry=$(find_entry "${preset}" "${hardware}")
    [[ -n ${entry} ]] || { echo "Preset ${preset} is not available for ${hardware}" >&2; exit 3; }
    IFS=$'\t' read -r _ _ profile tag _ <<<"${entry}"
    image="${registry}:${tag}"

    command -v cosign >/dev/null || { echo 'cosign is required to verify Purplefin images' >&2; exit 4; }
    command -v skopeo >/dev/null || { echo 'skopeo is required to resolve Purplefin images' >&2; exit 4; }
    digest=$(skopeo inspect --format '{{.Digest}}' "docker://${image}")
    [[ ${digest} =~ ^sha256:[0-9a-f]{64}$ ]] || { echo "Invalid digest for ${image}" >&2; exit 5; }
    immutable_image="${registry}@${digest}"
    cosign verify --certificate-oidc-issuer "${issuer}" --certificate-identity-regexp "${identity}" "${immutable_image}" >/dev/null
    printf '%s\n' "registry:${immutable_image}"
    ;;
  *) usage ;;
esac
